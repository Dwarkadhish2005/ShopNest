# ─── LLM Provider ────────────────────────────────────
# 'groq'   = FREE ✅  (recommended)
# 'openai' = paid
LLM_PROVIDER=groq

# ─── Groq (FREE — https://console.groq.com) ──────────
# Sign up free, create an API key, paste it below:
GROQ_API_KEY=your_groq_api_key_here

# Optional: change Groq model (default below is recommended)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenAI (paid fallback — set LLM_PROVIDER=openai) ─
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=gpt-3.5-turbo
